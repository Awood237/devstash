# Neon PostgreSQL connection string.
# Local development points at the Neon *development* branch; production uses
# its own branch. Use the direct (unpooled) connection string so Prisma
# migrations run cleanly.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: only needed if `prisma migrate dev` cannot create a shadow
# database on your Neon role. Point it at a separate empty Neon branch/db.
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME_shadow?sslmode=require"
